{
  "name": "shopify-resort-inventory-sort",
  "version": "1.0.0",
  "description": "Re-sort Shopify collection products by inventory with admin dashboard",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sort": "node --env-file=.env src/index.js",
    "sort:dry": "DRY_RUN=true node --env-file=.env src/index.js",
    "auth:install": "node --env-file=.env src/oauth-install.js",
    "migrate:shops": "node --env-file=.env src/migrate-shops-cli.js",
    "diagnose": "node --env-file=.env src/diagnose.js",
    "revert": "node --env-file=.env src/revert-collection.js",
    "webhooks:register": "node --env-file=.env src/register-webhooks.js",
    "seasonal:sync": "node --env-file=.env src/seasonal-cli.js",
    "seasonal:dry": "node --env-file=.env src/seasonal-cli.js --dry-run",
    "smart:sync": "node --env-file=.env src/smart-sync-cli.js",
    "smart:dry": "node --env-file=.env src/smart-sync-cli.js --dry-run",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --env-file=.env --watch server/index.js",
    "dev:web": "vite --config web/vite.config.js",
    "build:web": "vite build --config web/vite.config.js",
    "start": "node --env-file=.env server/index.js",
    "preview": "npm run build:web && npm run start"
  },
  "dependencies": {
    "@shopify/app-bridge-react": "^4.1.5",
    "@shopify/polaris": "^13.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.7"
  }
}
