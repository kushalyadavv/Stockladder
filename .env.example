SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_from_dev_dashboard
SHOPIFY_CLIENT_SECRET=your_client_secret_from_dev_dashboard

# Per-shop data lives under data/shops/{store}/ (config, snapshots, analytics, etc.)
# Run once after upgrade: npm run migrate:shops

# Legacy single-store CLI (optional — migrated into data/shops/ on startup):
# SHOPIFY_ACCESS_TOKEN=shpat_...
# SHOPIFY_REFRESH_TOKEN=shprt_...

DRY_RUN=false
PORT=3001
PUBLIC_URL=http://localhost:3001
# SHOPIFY_REDIRECT_URI=http://localhost:3001/auth/callback
# ALLOW_LEGACY_SINGLE_TENANT=true
# WEBHOOK_URL=https://your-deployed-app.com/api/webhooks/inventory
# BILLING_WEBHOOK_URL=https://your-deployed-app.com/api/webhooks/billing
# UNINSTALL_WEBHOOK_URL=https://your-deployed-app.com/api/webhooks/uninstall
# SHOPIFY_BILLING_TEST=true
# ALLOW_DEV_PLAN_SWITCH=true
